# Development and Production Environment Configuration

# ================================
# DEVELOPMENT ENVIRONMENT
# ================================

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi

# Database Configuration
DATABASE_URL=sqlite:///./kars_seo.db

# FastAPI Configuration
DEBUG=True
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ================================
# PRODUCTION ENVIRONMENT
# ================================
# Uncomment and modify for production deployment

# DEBUG=False
# LOG_LEVEL=WARNING

# Database (use PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@db.example.com:5432/kars_seo

# Security
# SECRET_KEY=your-secret-key-here
# ALLOWED_HOSTS=your-domain.com

# Email Configuration (for alerts/notifications)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Ollama (for large scale, consider hosted inference)
# OLLAMA_BASE_URL=https://api.ollama.example.com
